    "You'll return to onboarding and need the server URL and password to sign back in." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ستعود إلى المقدمة وستحتاج إلى عنوان URL للخادم وكلمة المرور لتسجيل الدخول مرة أخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Du kehrst zur Einrichtung zurück und benötigst die Server-URL und das Passwort, um dich wieder anzumelden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Regresarás a la introducción y necesitarás la URL del servidor y la contraseña para volver a iniciar sesión."
          }
