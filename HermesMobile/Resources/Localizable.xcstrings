    "Copy the agent setup prompt on your desktop before continuing so Hermes Web UI and Tailscale are configured correctly." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "انسخ مطالبة إعداد العميل على سطح المكتب قبل المتابعة لضمان إعداد Hermes Web UI وTailscale بشكل صحيح."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Kopiere den Agent-Einrichtungs-Prompt auf deinem Desktop, bevor du fortfährst, damit Hermes Web UI und Tailscale korrekt konfiguriert sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Copia el prompt de configuración del agente en tu escritorio antes de continuar para que Hermes Web UI y Tailscale se configuren correctamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Copiez l'invite de configuration de l'agent sur votre bureau avant de continuer afin que Hermes Web UI et Tailscale soient correctement configurés."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "העתק את הנחיית הגדרת הסוכן במחשב השולחני שלך לפני שתמשיך, כדי ש-Hermes Web UI ו-Tailscale יוגדרו כראוי."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Copia il prompt di configurazione dell'agente sul desktop prima di continuare per configurare correttamente Hermes Web UI e Tailscale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Hermes Web UIとTailscaleを正しく設定するため、続ける前にデスクトップでエージェント設定プロンプトをコピーしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Hermes Web UI와 Tailscale이 올바르게 구성되도록 계속하기 전에 데스크탑에서 에이전트 설정 프롬프트를 복사하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Kopieer de agent-installatieprompt op uw bureaublad voordat u doorgaat, zodat Hermes Web UI en Tailscale correct worden geconfigureerd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Skopiuj prompt konfiguracji agenta na pulpicie przed kontynuowaniem, aby Hermes Web UI i Tailscale były poprawnie skonfigurowane."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Copie o prompt de configuração do agente no seu computador antes de continuar para que a Hermes Web UI e o Tailscale sejam configurados corretamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Скопируйте запрос на настройку агента на компьютере, прежде чем продолжить, чтобы веб-интерфейс Hermes и Tailscale были настроены правильно."
          }
        },
        "tr" : {
          "stringUnit" : {
