    "Switch to %@ and start a new session. This keeps the current transcript on its original profile." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "التبديل إلى %@ وبدء جلسة جديدة. يُبقي هذا النص الحالي على ملف التعريف الأصلي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Zu %@ wechseln und eine neue Sitzung starten. Das aktuelle Transkript bleibt dabei auf seinem ursprünglichen Profil."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Cambiar a %@ e iniciar una nueva sesión. Esto mantiene la transcripción actual en su perfil original."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Basculer vers %@ et démarrer une nouvelle session. La transcription actuelle reste sur son profil d'origine."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "החלף אל %@ והתחל מפגש חדש. הפעולה משאירה את התמליל הנוכחי בפרופיל המקורי שלו."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Passa a %@ e avvia una nuova sessione. La trascrizione corrente rimane sul profilo originale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "%@ に切り替えて新しいセッションを開始します。現在のトランスクリプトは元のプロファイルに維持されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "%@(으)로 전환하고 새 세션을 시작해요. 현재 기록은 원래 프로필에 유지돼요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Schakel over naar %@ en start een nieuwe sessie. Het huidige transcript blijft op het oorspronkelijke profiel."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Przełącz na %@ i rozpocznij nową sesję. Bieżący transkrypt pozostanie na oryginalnym profilu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Alterne para %@ e inicie uma nova sessão. Isso mantém a transcrição atual no perfil original dela."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Переключиться на %@ и начать новую сессию. Текущая стенограмма останется в её исходном профиле."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "%@ profiline geç ve yeni bir oturum başlat. Bu, mevcut dökümü orijinal profilinde tutar."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "%@ پر منتقل ہو کر نیا سیشن شروع کریں۔ اس سے موجودہ ٹرانسکرپٹ اپنی اصل پروفائل پر برقرار رہتا ہے۔"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "切換至 %@ 並開始新工作階段。這會將目前的對話記錄保留在其原始設定檔上。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
