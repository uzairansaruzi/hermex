    "Makes this the active server. Sessions, chats, and settings reload for it." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يجعل هذا الخادم النشط. يُعاد تحميل الجلسات والمحادثات والإعدادات الخاصة به."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Macht diesen Server zum aktiven Server. Sitzungen, Chats und Einstellungen werden dafür neu geladen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Convierte este en el servidor activo. Las sesiones, chats y ajustes se recargan para él."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Définit ce serveur comme serveur actif. Les sessions, discussions et réglages se rechargent."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "הופך שרת זה לשרת הפעיל. מפגשים, צ׳אטים והגדרות ייטענו מחדש עבורו."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Imposta questo come server attivo. Sessioni, chat e impostazioni vengono ricaricate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "これをアクティブなサーバにします。セッション、チャット、設定が再読み込みされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "이 서버를 활성 서버로 설정해요. 세션, 채팅, 설정이 이 서버에 맞게 다시 불러와져요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Maakt dit de actieve server. Sessies, chats en instellingen worden hiervoor opnieuw geladen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ustawia ten serwer jako aktywny. Sesje, czaty i ustawienia zostaną przeładowane."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Torna este o servidor ativo. As sessões, os chats e os ajustes são recarregados para ele."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Делает этот сервер активным. Сессии, чаты и настройки перезагружаются для него."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Bunu etkin sunucu yapar. Oturumlar, sohbetler ve ayarlar bunun için yeniden yüklenir."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "اِسے فعال سرور بنا دیتا ہے۔ سیشنز، چیٹس اور ترتیبات اِس کے لیے دوبارہ لوڈ ہوتی ہیں۔"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "needs_review",
