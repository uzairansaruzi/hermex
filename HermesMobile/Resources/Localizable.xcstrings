    },
    "Hides the appended file-path line in your sent messages. Attachments still appear as previews, and the server still receives the paths." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يخفي سطر مسار الملف الملحق في رسائلك المرسلة. تظل المرفقات تظهر كمعاينات، ولا يزال الخادم يتلقى المسارات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Blendet die angehängte Dateipfad-Zeile in deinen gesendeten Nachrichten aus. Anhänge werden weiterhin als Vorschauen angezeigt, und der Server erhält die Pfade weiterhin."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Oculta la línea de ruta de archivo adjunta en tus mensajes enviados. Los adjuntos siguen apareciendo como vistas previas y el servidor sigue recibiendo las rutas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Masque la ligne de chemin de fichier dans vos messages envoyés. Les pièces jointes apparaissent toujours en aperçu et le serveur reçoit toujours les chemins."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "מסתיר את שורת נתיב הקובץ המצורפת בהודעות שאתה שולח. קבצים מצורפים עדיין מופיעים כתצוגות מקדימות, והשרת עדיין מקבל את הנתיבים."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Nasconde la riga del percorso file nei messaggi inviati. Gli allegati appaiono ancora come anteprime e il server riceve comunque i percorsi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "送信メッセージに追加されるファイルパスの行を非表示にします。添付ファイルはプレビューとして表示され、サーバには引き続きパスが送信されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "보낸 메시지에 추가되는 파일 경로 줄을 숨겨요. 첨부 파일은 미리보기로 계속 표시되며, 서버는 여전히 경로를 받아요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Verbergt de toegevoegde bestandspadregel in uw verzonden berichten. Bijlagen verschijnen nog steeds als voorbeelden en de server ontvangt de paden nog steeds."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ukrywa dołączoną linię ścieżki pliku w wysłanych wiadomościach. Załączniki nadal wyświetlają się jako podglądy, a serwer nadal otrzymuje ścieżki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Oculta a linha de caminho de arquivo adicionada às mensagens que você envia. Os anexos continuam aparecendo como pré-visualizações, e o servidor continua recebendo os caminhos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Скрывает добавляемую строку с путём к файлу в ваших отправленных сообщениях. Вложения по-прежнему отображаются в виде предпросмотров, а сервер по-прежнему получает пути."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Gönderdiğiniz mesajlardaki eklenmiş dosya yolu satırını gizler. Ekler yine önizleme olarak görünür ve sunucu yolları yine alır."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "آپ کے بھیجے گئے پیغامات میں شامل کی گئی فائل پاتھ کی سطر چھپاتا ہے۔ منسلکات اب بھی پیش منظر کے طور پر ظاہر ہوتے ہیں، اور سرور کو اب بھی پاتھس موصول ہوتے ہیں۔"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在你傳送的訊息中隱藏追加的檔案路徑行。附件仍會以預覽形式顯示，伺服器仍會收到這些路徑。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在你发送的消息中隐藏追加的文件路径行。附件仍会以预览形式显示，服务器仍会收到这些路径。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在你傳送的訊息中隱藏附加的檔案路徑行。附件仍會以預覽形式顯示，伺服器仍會收到這些路徑。"
          }
        }
      }
    },
