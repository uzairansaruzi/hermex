    "iOS blocked this insecure HTTP connection. Use HTTPS, or use a Tailscale IP in the 100.64.0.0/10 range." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "حظر iOS اتصال HTTP غير الآمن هذا. استخدم HTTPS، أو استخدم عنوان IP من Tailscale ضمن النطاق 100.64.0.0/10."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS hat diese unsichere HTTP-Verbindung blockiert. Verwende HTTPS oder eine Tailscale-IP im Bereich 100.64.0.0/10."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS bloqueó esta conexión HTTP insegura. Usa HTTPS o una IP de Tailscale en el rango 100.64.0.0/10."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS a bloqué cette connexion HTTP non sécurisée. Utilisez HTTPS ou une adresse IP Tailscale dans la plage 100.64.0.0/10."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS חסם חיבור HTTP לא מאובטח זה. השתמש ב-HTTPS, או השתמש בכתובת IP של Tailscale בטווח 100.64.0.0/10."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS ha bloccato questa connessione HTTP non sicura. Usa HTTPS o un IP Tailscale nell'intervallo 100.64.0.0/10."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOSがこの安全でないHTTP接続をブロックしました。HTTPSを使用するか、100.64.0.0/10 の範囲のTailscale IPを使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS가 이 안전하지 않은 HTTP 연결을 차단했어요. HTTPS를 사용하거나 100.64.0.0/10 범위의 Tailscale IP를 사용하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS heeft deze onveilige HTTP-verbinding geblokkeerd. Gebruik HTTPS of gebruik een Tailscale-IP in het bereik 100.64.0.0/10."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS zablokował to niezabezpieczone połączenie HTTP. Użyj HTTPS lub adresu IP Tailscale z zakresu 100.64.0.0/10."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "O iOS bloqueou esta conexão HTTP insegura. Use HTTPS ou um IP do Tailscale na faixa 100.64.0.0/10."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS заблокировал это небезопасное HTTP-соединение. Используйте HTTPS или IP-адрес Tailscale в диапазоне 100.64.0.0/10."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS bu güvenli olmayan HTTP bağlantısını engelledi. HTTPS kullanın veya 100.64.0.0/10 aralığında bir Tailscale IP'si kullanın."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iOS نے اس غیر محفوظ HTTP کنکشن کو روک دیا۔ HTTPS استعمال کریں، یا 100.64.0.0/10 رینج میں کوئی Tailscale IP استعمال کریں۔"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "needs_review",
