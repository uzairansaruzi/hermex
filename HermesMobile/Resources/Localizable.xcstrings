    "This workspace has uncommitted changes. Save them temporarily, switch branches, then restore any saved changes for the destination branch." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dieser Arbeitsbereich enthält nicht festgeschriebene Änderungen. Speichern Sie sie vorübergehend, wechseln Sie die Zweige und stellen Sie dann alle gespeicherten Änderungen für den Zielzweig wieder her."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Este espacio de trabajo tiene cambios no confirmados. Guárdelos temporalmente, cambie de rama y luego restaure los cambios guardados para la rama de destino."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Cet espace de travail comporte des modifications non validées. Enregistrez-les temporairement, changez de branche, puis restaurez toutes les modifications enregistrées pour la branche de destination."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Quest'area di lavoro presenta modifiche non confermate. Salvali temporaneamente, cambia ramo, quindi ripristina eventuali modifiche salvate per il ramo di destinazione."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ten obszar roboczy zawiera niezatwierdzone zmiany. Zapisz je tymczasowo, zmień gałęzie, a następnie przywróć wszelkie zapisane zmiany dla gałęzi docelowej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Este espaço de trabalho tem alterações não confirmadas. Salve-os temporariamente, troque de ramificação e restaure as alterações salvas na ramificação de destino."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Deze werkruimte bevat niet-vastgelegde wijzigingen. Sla ze tijdelijk op, wissel van vertakking en herstel vervolgens alle opgeslagen wijzigingen voor de doelvertakking."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Bu çalışma alanında kaydedilmemiş değişiklikler var. Bunları geçici olarak kaydedin, dalları değiştirin ve ardından hedef dal için kaydedilen değişiklikleri geri yükleyin."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "В этой рабочей области есть незафиксированные изменения. Временно сохраните их, переключите ветку, а затем восстановите все сохраненные изменения для целевой ветки."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "このワークスペースにはコミットされていない変更が含まれています。それらを一時的に保存し、ブランチを切り替えてから、保存された変更を宛先ブランチに復元します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "此工作区有未提交的更改。暂时保存它们，切换分支，然后恢复目标分支的所有已保存更改。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "이 작업공간에는 커밋되지 않은 변경사항이 있습니다. 임시로 저장하고 분기를 전환한 다음 대상 분기에 대해 저장된 변경 사항을 복원합니다."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "تحتوي مساحة العمل هذه على تغييرات متاحة. احفظها مؤقتًا، وقم بتبديل الفروع، ثم قم باستعادة أي تغييرات محفوظة للفرع الوجهة."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "בסביבת העבודה הזו יש שינויים לא מחויבים. שמור אותם באופן זמני, החלף סניפים ואז שחזר את כל השינויים השמורים עבור סניף היעד."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "اس ورک اسپیس میں غیر منظم تبدیلیاں ہیں۔ انہیں عارضی طور پر محفوظ کریں، شاخوں کو تبدیل کریں، پھر منزل کی شاخ کے لیے کسی بھی محفوظ شدہ تبدیلی کو بحال کریں۔"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "此工作區有未提交的變更。暫時儲存它們，切換分支，然後恢復目標分支的所有已儲存變更。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "此工作區有未提交的變更。暫時儲存它們，切換分支，然後恢復目標分支的所有已儲存變更。"
          }
        }
      }
    },
