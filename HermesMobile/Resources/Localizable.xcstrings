          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "جاری رکھنے سے پہلے اپنے ڈیسک ٹاپ پر ایجنٹ سیٹ اپ پرامپٹ کاپی کریں تاکہ Hermes Web UI اور Tailscale درست طریقے سے ترتیب دیے جائیں۔"
          }
        },
        "zh-HK" : {
