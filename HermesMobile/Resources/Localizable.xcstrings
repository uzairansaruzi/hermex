        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "הכוונה לא הייתה זמינה, ולכן ההודעה הוכנסה לתור והתגובה הנוכחית נעצרה."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
