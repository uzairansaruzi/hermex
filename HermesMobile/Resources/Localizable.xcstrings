        },
        "ur" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "اپنے iPhone پر Tailscale انسٹال کریں اور اپنے سرور والے اسی tailnet میں سائن اِن کریں۔ اگلی اسکرین پر آپ کا ایجنٹ استعمال کرنے کے لیے درست URL کے ساتھ جواب دے گا۔"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
