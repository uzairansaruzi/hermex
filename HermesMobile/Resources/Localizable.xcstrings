          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lokalny plik obszaru roboczego zastępuje globalny kontekst projektu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
