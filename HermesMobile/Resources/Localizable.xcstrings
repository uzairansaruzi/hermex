    "Fades words in as a response streams. Turn off to show text instantly." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يُظهر الكلمات تدريجيًا أثناء بث الرد. أوقِف التشغيل لعرض النص فورًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Blendet Wörter ein, während eine Antwort gestreamt wird. Schalte es aus, um Text sofort anzuzeigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Muestra las palabras gradualmente mientras se transmite la respuesta. Desactívalo para mostrar el texto de inmediato."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Fait apparaître les mots progressivement lors de la diffusion d'une réponse. Désactivez pour afficher le texte instantanément."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "מחדיר מילים בהדרגה בעת הזרמת תגובה. כבה כדי להציג טקסט באופן מיידי."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dissolvenza delle parole durante lo streaming. Disattiva per mostrare il testo immediatamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "応答のストリーミング中に単語をフェードインさせます。オフにするとテキストを即座に表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "응답이 스트리밍될 때 단어를 서서히 나타나게 해요. 끄면 텍스트가 즉시 표시돼요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Laat woorden geleidelijk verschijnen terwijl een antwoord streamt. Schakel dit uit om tekst direct weer te geven."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Wygasza słowa podczas przesyłania strumieniowego odpowiedzi. Wyłącz, aby wyświetlać tekst natychmiast."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Faz as palavras surgirem gradualmente conforme a resposta é transmitida. Desative para mostrar o texto instantaneamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Плавно проявляет слова по мере потоковой передачи ответа. Отключите, чтобы показывать текст мгновенно."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Bir yanıt akarken sözcükleri belirginleştirir. Metni anında göstermek için kapatın."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "جواب اسٹریم ہوتے ہوئے الفاظ کو دھیرے دھیرے ظاہر کرتا ہے۔ متن فوری دکھانے کے لیے بند کریں۔"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在回覆串流時讓文字淡入。關閉後即時顯示文字。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在回复流式传输时让文字淡入。关闭后即时显示文本。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在回覆串流時讓文字淡入。關閉後即時顯示文字。"
          }
        }
      }
    },
