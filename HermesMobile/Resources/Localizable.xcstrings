    "Steer was unavailable, so the message was queued and the current response was stopped." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "التوجيه غير متاح، لذا وُضعت الرسالة في قائمة الانتظار وأُوقف الرد الحالي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Steuern war nicht verfügbar, daher wurde die Nachricht in die Warteschlange gestellt und die aktuelle Antwort gestoppt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La dirección no estaba disponible, por lo que el mensaje se puso en cola y la respuesta actual se detuvo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
