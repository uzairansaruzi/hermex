    "/background is available for WebUI sessions only." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background متاح لجلسات WebUI فقط."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background ist nur für WebUI-Sitzungen verfügbar."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background solo está disponible en sesiones de WebUI."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background est disponible uniquement pour les sessions WebUI."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background זמין למפגשי WebUI בלבד."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background è disponibile solo per le sessioni WebUI."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background はWebUIセッションでのみ使用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background는 WebUI 세션에서만 사용할 수 있어요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background is alleen beschikbaar voor WebUI-sessies."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background jest dostępne tylko dla sesji WebUI."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background está disponível apenas para sessões do WebUI."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "/background доступна только для сессий WebUI."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "needs_review",
